# Build artifacts
build/
out/
bin/

# Portable test bundle assembled for hand-off to another machine.
# Contains binary win-ldac.exe + VC++ runtime DLLs + assets + firmware.
# Per the BTstack licence we don't redistribute compiled binaries, so
# the bundle stays out of source control.
dist/
*.obj
*.lib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# IDE
.vs/
.vscode/
*.user
*.suo
*.sln.iobj
*.sln.ipdb
CMakeUserPresets.json

# User-fetched dependency (see HANDOFF.md §4.2; BTstack license forbids us bundling it)
vendor/btstack/

# (Dear ImGui and ImPlot are now tracked as git submodules — see
# .gitmodules. The lines that used to exclude them have been removed.)

# Bundled UI assets are now committed (Maple Mono under SIL OFL 1.1,
# monkey + pic both open-source per the project owner). Anything other
# than the curated set below stays out of source control.
assets/*
!assets/README.md
!assets/OFL.txt
!assets/MapleMono-Regular.ttf
!assets/monkey.png
!assets/pic.png
!assets/win-ldac.ico

